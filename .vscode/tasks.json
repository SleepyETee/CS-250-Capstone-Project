{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang",
            "args": [
                        "-std=c++17",                // <‑‑ add this
                        "-Wall",
                        "-Wextra",
                        "-g3",
                        "${workspaceFolder}/Source Files/*.cpp",   // <‑‑ compile ALL .cpp files
                        "-o",
                        "${workspaceFolder}/Source Files/output/WorkshopHub"
                    ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}